# --- Runtime / server ---
ENVIRONMENT=development
PORT=8000
# Allowed browser origin(s), comma-separated. In production set this to your Vercel
# URL, e.g. https://dealwing.vercel.app (any *.vercel.app preview is allowed anyway).
CORS_ORIGIN=http://localhost:5173

# --- Storage ---
DB_URL=sqlite:///./data/tgagent.db
RAW_SNAPSHOT_DIR=./data/raw_snapshots

# --- Dashboard auth (DealWing login) ---
AUTH_SECRET=change-me
ADMIN_EMAIL=admin@dealwing.local
ADMIN_PASSWORD=change-me

# --- Telegram MTProto (owned channels) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION_NAME=tga_user
# Channels to COLLECT + LEARN from (the real channel, e.g. GrabOnIndiaOfficial).
# Setting this does NOT make anything post there — see PUBLISH_CHANNEL.
OWNED_CHANNELS=
COMPETITOR_CHANNELS=

# The ONE channel auto-send is allowed to post to. BLANK => auto-send is held for
# every channel (safe default; posts still get planned, written and queued, they
# just never leave). Point it at a test channel to review real output privately;
# only set it to the live channel when every planned post should go out publicly.
PUBLISH_CHANNEL=

# --- AI (provider-selectable: openai reasoning | groq) ---
# AI_PROVIDER: openai | groq. Unset => openai when OPENAI_API_KEY is set, else groq.
# AI_MODEL overrides the per-provider default (openai: gpt-5-mini-2025-08-07, groq: llama-3.3-70b-versatile).
# AI_REASONING_EFFORT: minimal|low|medium|high — default thinking budget for reasoning models (no-op on groq).
AI_PROVIDER=openai
OPENAI_API_KEY=
GROQ_API_KEY=
AI_MODEL=gpt-5-mini-2025-08-07
AI_REASONING_EFFORT=medium

# --- Deal source (GrabCash) ---
DEAL_API_BASE=https://deals.grabcash.in/api/v1/deals
DEAL_API_AUTH=header:X-API-Key
API_SECRET_KEY=

# --- Affiliate (GrabOn) ---
AFFILIATE_PROVIDER=grabon
GRABON_SHORTENER_URL=https://shortner-api.grabon.com/api/url/shorten
GRABON_AMAZON_TAG=tlg022-21
GRABON_FLIPKART_PARAMS=affid=bh7162&affExtParam1=1005&affExtParam2=gb
GRABON_SHORTEN_ALL=true

# Auto-run the 20 scheduler cron jobs when the server starts (default off)
SCHEDULERS_AUTOSTART=false

# --- Publishing (Phase 0.3) ---
# a deal older than this many minutes is revalidated (price/stock/liveness) before
# a queued post is allowed to publish; a failed revalidation BLOCKs the post.
PREPUBLISH_MAX_STALENESS_MIN=30
