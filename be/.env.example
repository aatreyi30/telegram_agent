# --- Runtime / server ---
ENVIRONMENT=development
PORT=8000
CORS_ORIGIN=http://localhost:5173

# --- Storage ---
DB_URL=sqlite:///./data/tgagent.db
RAW_SNAPSHOT_DIR=./data/raw_snapshots

# --- Dashboard auth (DealWing login) ---
AUTH_SECRET=change-me
ADMIN_EMAIL=admin@dealwing.local
ADMIN_PASSWORD=change-me

# --- Telegram MTProto (owned channels) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION_NAME=tga_user
OWNED_CHANNELS=
COMPETITOR_CHANNELS=

# --- AI (Groq) ---
GROQ_API_KEY=
AI_MODEL=llama-3.3-70b-versatile

# --- Deal source (GrabCash) ---
DEAL_API_BASE=https://deals.grabcash.in/api/v1/deals
DEAL_API_AUTH=header:X-API-Key
API_SECRET_KEY=

# --- Affiliate (GrabOn) ---
AFFILIATE_PROVIDER=grabon
GRABON_SHORTENER_URL=https://shortner-api.grabon.com/api/url/shorten
GRABON_AMAZON_TAG=tlg022-21
GRABON_FLIPKART_PARAMS=affid=bh7162&affExtParam1=1005&affExtParam2=gb
GRABON_SHORTEN_ALL=true
